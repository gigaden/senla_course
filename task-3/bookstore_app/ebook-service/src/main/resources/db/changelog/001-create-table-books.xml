<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.5.xsd"
        logicalFilePath="db/changelog.xml">
    <changeSet id="001-create-table-books" author="gigaden">
        <createTable tableName="books">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(256)">
                <constraints nullable="false"/>
            </column>
            <column name="author" type="VARCHAR(256)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="date_of_publication" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="FLOAT">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(256)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <sql>
            ALTER TABLE books
                ADD CONSTRAINT ch_book_price CHECK (price > 0);
            ALTER TABLE books
                ADD CONSTRAINT ch_book_status CHECK (status IN ('AVAILABLE', 'ABSENT'));
        </sql>
        <rollback>
            <dropTable tableName="books"/>
        </rollback>
    </changeSet>
</databaseChangeLog>