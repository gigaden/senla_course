<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.5.xsd"
        logicalFilePath="db/changelog.xml">
    <changeSet id="004-create-table-requests" author="gigaden">
        <createTable tableName="requests">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="book_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_requests_books"
                             referencedTableName="books" referencedColumnNames="id"/>
            </column>
            <column name="client_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_requests_clients"
                             referencedTableName="clients" referencedColumnNames="id"/>
            </column>
            <column name="request_status" type="VARCHAR(128)" defaultValue="OPENED">
                <constraints nullable="true"/>
            </column>
            <column name="created_on" type="DATE" defaultValueDate="CURRENT_DATE">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <sql>
            ALTER TABLE requests
                ADD CONSTRAINT ch_request_status
                    CHECK (request_status IN ('OPENED', 'CLOSED'));
        </sql>

        <rollback>
            <dropTable tableName="requests"/>
        </rollback>
    </changeSet>
</databaseChangeLog>