            <column name="status" value="AVAILABLE"/>
        </insert>

        <insert tableName="books">
            <column name="title" value="Гарри Поттер и философский камень"/>
            <column name="author" value="Дж. К. Роулинг"/>
            <column name="description" value="Первая книга серии о юном волшебнике Гарри Поттере."/>
            <column name="date_of_publication" valueDate="1997-06-26"/>
            <column name="price" valueNumeric="300.00"/>
            <column name="status" value="AVAILABLE"/>
        </insert>

        <insert tableName="books">
            <column name="title" value="Маленький принц"/>
            <column name="author" value="Антуан де Сент-Экзюпери"/>
            <column name="description" value="Философская сказка о путешествиях маленького принца."/>
            <column name="date_of_publication" valueDate="1943-04-06"/>
            <column name="price" valueNumeric="250.00"/>
            <column name="status" value="AVAILABLE"/>
        </insert>

        <insert tableName="books">
            <column name="title" value="Алиса в Стране чудес"/>
            <column name="author" value="Льюис Кэрролл"/>
            <column name="description" value="Сказка о девочке Алисе, попадающей в подземную страну чудес."/>
            <column name="date_of_publication" valueDate="1865-11-26"/>
            <column name="price" valueNumeric="350.00"/>
            <column name="status" value="ABSENT"/>
        </insert>

        <insert tableName="books">
            <column name="title" value="Шерлок Холмс"/>
            <column name="author" value="Артур Конан Дойл"/>
            <column name="description" value="Сборник рассказов о знаменитом детективе Шерлоке Холмсе."/>
            <column name="date_of_publication" valueDate="1892-01-01"/>
            <column name="price" valueNumeric="400.00"/>
            <column name="status" value="AVAILABLE"/>
        </insert>

        <rollback>
            <delete tableName="books">
                <where>title IN ('Война и мир', 'Преступление и наказание', 'Мастер и Маргарита',
                    '1984', 'Улисс', 'Властелин колец', 'Гарри Поттер и философский камень',
                    'Маленький принц', 'Алиса в Стране чудес', 'Шерлок Холмс')
                </where>
            </delete>
        </rollback>
    </changeSet>

